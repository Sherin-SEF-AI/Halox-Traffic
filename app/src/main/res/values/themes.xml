<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Post-splash base theme. Compose drives the actual UI; this sets window/system-bar colors. -->
    <style name="Theme.HaloxTraffic" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bg_void</item>
        <item name="android:statusBarColor">@color/bg_void</item>
        <item name="android:navigationBarColor">@color/bg_void</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Launch theme using the AndroidX SplashScreen API. -->
    <style name="Theme.HaloxTraffic.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_void</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.HaloxTraffic</item>
    </style>
</resources>
